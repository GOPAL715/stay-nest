# ============================================================
# StayNest — Environment Variables
# Copy this file to .env and fill in all values before running
# NEVER commit .env to version control
# ============================================================

# ----- PostgreSQL -----
POSTGRES_DB=staynest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_db_password_here

# ----- JWT (REQUIRED — generate a secure 256-bit hex secret) -----
# Generate: openssl rand -hex 32
JWT_SECRET=your_256_bit_hex_secret_here
JWT_ACCESS_EXPIRY_MS=900000       # 15 minutes
JWT_REFRESH_EXPIRY_MS=604800000   # 7 days

# ----- Email (SMTP) -----
MAIL_HOST=smtp.sendgrid.net       # Use mailhog for local: localhost
MAIL_PORT=587                     # Use 1025 for MailHog
MAIL_USERNAME=apikey
MAIL_PASSWORD=your_sendgrid_api_key_here
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
EMAIL_FROM=noreply@staynest.com

# ----- Application URLs -----
APP_BASE_URL=http://localhost:8080
FRONTEND_CUSTOMER_URL=http://localhost:5173
FRONTEND_ADMIN_URL=http://localhost:5174

# ----- Spring Profile -----
SPRING_PROFILES_ACTIVE=dev

# ----- Payments (demo mode — default, no keys needed) -----
PAYMENTS_DEMO_MODE=true

# ----- Razorpay (optional — only if PAYMENTS_DEMO_MODE=false) -----
# RAZORPAY_KEY_ID=rzp_test_your_key_id
# RAZORPAY_KEY_SECRET=your_razorpay_test_secret
